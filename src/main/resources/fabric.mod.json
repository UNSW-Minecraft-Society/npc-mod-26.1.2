{
	"schemaVersion": 1,
	"id": "npc-mod",
	"version": "${version}",
	"name": "Veveddo's NPC mod",
	"description": "A simple mod that implements NPCs",
	"authors": [
		"Veveddo"
	],
	"contact": {
		"homepage": "https://mc.unswminecraft.com",
		"sources": ""
	},
	"license": "CC0-1.0",
	"icon": "assets/npc-mod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"mcsoc.npcmod.NPCMod"
		],
		"client": [
			"mcsoc.npcmod.NPCModClient"
		]
	},
	"mixins": [
		"npc-mod.mixins.json",
		{
			"config": "npc-mod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-key-binding-api-v1": "*"
	},
	"suggests": {
		"another-mod": "*"
	},
	"custom": {
  		"mixin.debug": true
	}
}